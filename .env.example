# Copie para um arquivo fora do repositorio e proteja com chmod 600.
OPER_RADAR_DB_HOST=localhost
OPER_RADAR_DB_USER=usuario_mysql
OPER_RADAR_DB_PASS=senha_mysql
OPER_RADAR_DB_NAME=banco_mysql

# Token da API FIPE. Deixe vazio enquanto a assinatura ainda nao estiver ativa.
FIPE_API_TOKEN=
# Plano PRO: consultas ilimitadas e carga completa mensal.
FIPE_API_UNLIMITED=1

# Consulta por placa (servico separado da FIPE Online).
# Provedor suportado: webxcar. A chave nunca deve ir para o frontend.
OPER_RADAR_PLACA_PROVIDER=webxcar
OPER_RADAR_PLACA_API_TOKEN=
